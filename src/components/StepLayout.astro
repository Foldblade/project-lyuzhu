---
export interface Props {
  maxWidth?: string;
  noPadding?: boolean;
  noScroll?: boolean;
}

const { maxWidth, noPadding, noScroll } = Astro.props;
---

<div
  class:list={[
    "flex flex-col items-center w-full h-full pt-2",
    { "px-4": !noPadding, "overflow-y-auto": !noScroll },
  ]}
>
  <div
    class="flex flex-col items-center w-full h-full min-h-0"
    style={`max-width:${maxWidth ?? "none"}`}
  >
    <slot />
    </div>
  </div>
