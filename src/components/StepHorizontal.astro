---
import type { StreamItem } from "../data/types";
import StepLayout from "./StepLayout.astro";
import type { BambooData } from "../data/types";

export interface Props {
  data: BambooData;
}

const { data } = Astro.props;

const delimiterChar = (kind: string) => (kind === "comma" ? "、" : "。");
const punctName = (slice: StreamItem[], idx: number) => {
  const prev = slice[idx - 1];
  return prev?.type === "glyph" ? `p-${prev.glyphId}` : undefined;
};
function charSrc(glyphId: string) {
  return `/assets/1/${data.glyphPool[glyphId].charArt}.svg`;
}
---

<StepLayout maxWidth="600px">
  <div class="my-auto w-full flex flex-col gap-8">
  {
    data.horizontalStreams.map((stream) => (
      <div class="flex flex-wrap justify-start gap-0.5">
        {stream.map((i, idx) =>
          i.type === "delimiter" ? (
            <div class="flex flex-col items-center" style="width:20px">
              <div style="height:38px" />
              <span class="text-red text-body leading-tight" transition:name={punctName(stream, idx)}>
                {delimiterChar(i.kind)}
              </span>
            </div>
          ) : (
            <div class="flex flex-col items-center" style="width:28px">
              <div
                class="flex items-center justify-center"
                style="height:38px;width:28px"
              >
                <img
                  src={charSrc(i.glyphId)}
                  alt={data.glyphPool[i.glyphId].glyph}
                  class="glyph-img max-w-full max-h-full object-contain"
                  transition:name={data.glyphPool[i.glyphId].id}
                />
              </div>
              <span class="text-warm text-body leading-tight text-center font-normal" transition:name={`m-${data.glyphPool[i.glyphId].id}`}>
                {data.glyphPool[i.glyphId].glyph}
              </span>
              {data.glyphPool[i.glyphId].modernChar && (
                <span class="text-gold text-caption leading-tight opacity-70" transition:name={`c-${data.glyphPool[i.glyphId].id}`}>
                  [{data.glyphPool[i.glyphId].modernChar}]
                </span>
              )}
            </div>
          ),
        )}
      </div>
    ))
  }
  </div>
</StepLayout>
