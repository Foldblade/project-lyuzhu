---
export interface Props {
  animEndMs: number;
}

const { animEndMs } = Astro.props;
---

<div id="step0-overlay" class="absolute inset-0 z-40 opacity-0 transition-opacity duration-700 ease-in-out glass-container" aria-hidden="true" data-anim-end={animEndMs} style="-webkit-backdrop-filter:blur(8px);backdrop-filter:blur(8px)">
  <div class="absolute inset-0" style="background:rgba(26,26,26,0.4)"></div>

  <div class="absolute left-4 top-1/2 -translate-y-1/2 flex flex-col items-center gap-2 pointer-events-none">
    <svg class="w-8 h-8 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
    <span id="oHintPrev" class="text-muted text-caption tracking-[0.2em] uppercase"></span>
  </div>

  <div class="absolute right-4 top-1/2 -translate-y-1/2 flex flex-col items-center gap-2 pointer-events-none">
    <svg class="w-8 h-8 text-gold" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
    <span id="oHintNext" class="text-muted text-caption tracking-[0.2em] uppercase"></span>
  </div>

  <div class="absolute left-1/2 -translate-x-1/2 top-1/2 -translate-y-1/2 flex flex-col items-center gap-5 pointer-events-none">
    <div class="flex items-center gap-3">
      <svg class="w-6 h-6 text-gold/70" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="7"/><path d="M12 6v4"/></svg>
      <span id="oHintScroll" class="text-warm/80 text-sm tracking-wider"></span>
    </div>
    <div class="flex items-center gap-3">
      <svg class="w-6 h-6 text-gold/70" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M6 8h.01M10 8h.01M14 8h.01M18 8h.01M8 12h.01M12 12h.01M16 12h.01M8 16h8"/></svg>
      <span id="oHintKeys" class="text-warm/80 text-sm tracking-wider"></span>
    </div>
    <div class="flex flex-col items-center gap-1.5">
      <button id="overlayClose" type="button" class="w-7 h-7 flex items-center justify-center border border-warm/30 rounded-sm pointer-events-auto cursor-pointer hover:border-warm/60 focus-visible:ring-2 focus-visible:ring-gold focus-visible:outline-none transition-colors">
        <svg class="w-4 h-4 text-warm/60" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <span id="oHintClose" class="text-warm/50 text-caption tracking-[0.15em] uppercase"></span>
    </div>
  </div>

  <div class="absolute bottom-4 right-4 flex items-center gap-2 pointer-events-none">
    <span id="oHintLang" class="text-muted text-caption"></span>
    <svg class="w-4 h-4 text-muted" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14"/><path d="m19 12-7 7-7-7"/></svg>
  </div>
</div>
