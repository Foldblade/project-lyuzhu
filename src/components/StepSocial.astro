---
import StepLayout from "./StepLayout.astro";
import Trans from "./Trans.astro";
---

<StepLayout maxWidth="600px">
  <div class="my-auto w-full flex flex-col gap-6">
    <Trans
      key="socialInfo.title"
      as="h2"
      class="text-gold text-heading font-normal tracking-label"
    />

    <Trans
      key="socialInfo.body"
      as="p"
      class="text-warm text-sm leading-relaxed text-center"
      html
    />

    <div class="flex flex-col gap-3 w-full">
      <a
        href="https://fetlife.com/f37c7d70/pictures/221286839"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center justify-center gap-2 border border-brown rounded px-4 py-2 text-warm text-sm transition-colors hover:border-gold hover:text-gold"
      >
        Fetlife
      </a>
      <Trans
        key="socialInfo.instagram"
        as="p"
        class="text-warm text-sm leading-relaxed text-center"
      />
      <a
        href="https://www.instagram.com/f37c7d70/"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        class="flex items-center justify-center border border-brown rounded px-4 py-2 text-warm transition-colors hover:border-gold hover:text-gold"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
          <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
          <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
        </svg>
      </a>
    </div>

    <Trans
      key="socialInfo.footer"
      as="p"
      class="text-muted text-xs leading-relaxed text-center"
      html
    />
  </div>
</StepLayout>
