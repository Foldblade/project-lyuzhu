---
import i18n from "../i18n";
import { bamboo1 } from "../data/bamboo-1";
import StepOriginal from "../components/StepOriginal.astro";
import StepModern from "../components/StepModern.astro";
import StepPunctuated from "../components/StepPunctuated.astro";
import StepHorizontal from "../components/StepHorizontal.astro";
import StepTranslation from "../components/StepTranslation.astro";
import StepSocial from "../components/StepSocial.astro";
import StepStatusBar from "../components/StepStatusBar.astro";
import Step0Overlay from "../components/Step0Overlay.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { ANIM_ROW_STAGGER, ANIM_DURATION } from "../data/anim-constants";

export async function getStaticPaths() {
  return [{ params: { id: "1" } }];
}

const { id } = Astro.params;
const data = { "1": bamboo1 }[id!];
if (!data) return Astro.redirect("/404");

const labels = {
  "zh-Hant": i18n.t("stepLabels", { returnObjects: true, lng: "zh-Hant" }) as string[],
  "zh-Hans": i18n.t("stepLabels", { returnObjects: true, lng: "zh-Hans" }) as string[],
  en: i18n.t("stepLabels", { returnObjects: true, lng: "en" }) as string[],
};
const components = [
  StepOriginal,
  StepModern,
  StepPunctuated,
  StepHorizontal,
  StepTranslation,
  StepSocial,
];
const total = components.length;

// Animation timing — matches ANIM_ROW_STAGGER / ANIM_DURATION from anim-constants
const maxRows = 15;
const colDuration = maxRows * ANIM_ROW_STAGGER + ANIM_DURATION;
const lastColStart = (data.layout.length - 1) * colDuration;
const lastRowStart = lastColStart + (maxRows - 1) * ANIM_ROW_STAGGER;
const totalAnimMs = Math.ceil((lastRowStart + ANIM_DURATION) * 1000) + 300;
---

<BaseLayout title={data.name.zhHant}>
  <h1 class="sr-only">{data.name.zhHant}</h1>
  <div id="reader" class="flex flex-col h-dvh bg-dark-bg overflow-hidden relative" transition:name="reader" data-language="en">
    <div class="flex-1 relative w-full overflow-hidden" id="stepContent" aria-live="polite">
      {components.map((Step, i) => (
        <div class="step absolute inset-0 flex items-center justify-center" class:list={{ "step-hidden": i !== 0 }}>
          <Step data={data} />
        </div>
      ))}
      <button id="zonePrev" type="button" class="absolute left-0 top-0 bottom-0 w-[max(64px,8vw)] z-10 cursor-pointer focus-visible:ring-2 focus-visible:ring-gold focus-visible:outline-none"></button>
      <button id="zoneNext" type="button" class="absolute right-0 top-0 bottom-0 w-[max(64px,8vw)] z-10 cursor-pointer focus-visible:ring-2 focus-visible:ring-gold focus-visible:outline-none"></button>

      <Step0Overlay animEndMs={totalAnimMs} />
    </div>
    <StepStatusBar labels={labels} current={0} />
  </div>

  <script>
    import i18n from "../i18n";

    const reader = document.getElementById("reader")!;
    const steps = reader.querySelectorAll<HTMLElement>(".step");
    const stepContent = document.getElementById("stepContent")!;
    const btns = reader.querySelectorAll<HTMLElement>("#stepNav .step-btn");
    const zonePrev = document.getElementById("zonePrev")!;
    const zoneNext = document.getElementById("zoneNext")!;
    const total = 6;
    let current = 0;

    function switchLang(lang: string) {
      reader.dataset.language = lang;
      zonePrev.setAttribute("aria-label", i18n.t("nav.prev", { lng: lang }));
      zoneNext.setAttribute("aria-label", i18n.t("nav.next", { lng: lang }));
      const labels = i18n.t("stepLabels", { returnObjects: true, lng: lang }) as string[];
      btns.forEach((btn, i) => btn.setAttribute("aria-label", labels[i]));
      document.querySelectorAll<HTMLElement>(".langSwitch button").forEach((btn) => {
        btn.setAttribute("aria-pressed", String(btn.dataset.switchLang === lang));
      });
      updateStep0Overlay(lang);
    }

    function detectBrowserLang(): string {
      const params = new URLSearchParams(location.search);
      const forced = params.get("lang");
      if (forced === "zh-Hant" || forced === "zh-Hans") return forced;
      const navLang = navigator.language;
      if (navLang.startsWith("zh")) {
        return navLang.startsWith("zh-CN") || navLang.startsWith("zh-SG") || navLang.startsWith("zh-MY") ? "zh-Hans" : "zh-Hant";
      }
      return "en";
    }

    const oHintKeys: Record<string, string[]> = {
      prev: ["oHintPrev", "step0Hint.prev"],
      next: ["oHintNext", "step0Hint.next"],
      scroll: ["oHintScroll", "step0Hint.scroll"],
      keys: ["oHintKeys", "step0Hint.keys"],
      close: ["oHintClose", "step0Hint.close"],
      lang: ["oHintLang", "step0Hint.lang"],
    };

    function updateStep0Overlay(lang: string) {
      for (const [, [id, key]] of Object.entries(oHintKeys)) {
        const el = document.getElementById(id);
        if (el) el.textContent = i18n.t(key, { lng: lang });
      }
      const closeBtn = document.getElementById("overlayClose");
      if (closeBtn) closeBtn.setAttribute("aria-label", i18n.t("step0Hint.close", { lng: lang }));
    }

    switchLang(detectBrowserLang());

    document.querySelectorAll<HTMLElement>(".langSwitch button").forEach((btn) => {
      btn.addEventListener("click", () => switchLang(btn.dataset.switchLang!));
    });

    function showStep(n: number) {
      hideStep0Overlay();
      if (n === current || n < 0 || n >= total) return;
      document.startViewTransition(() => {
        steps[current].classList.add("step-hidden");
        steps[n].classList.remove("step-hidden");
        current = n;
      });
      btns.forEach((el, i) => {
        const dot = el.querySelector("span")!;
        dot.classList.toggle("bg-gold", i === n);
        dot.classList.toggle("bg-brown/50", i !== n);
      });
      document.querySelectorAll<HTMLElement>("#stepLabel > [data-step]").forEach((el) => {
        el.classList.toggle("hidden", Number(el.dataset.step) !== n);
      });
    }

    btns.forEach((btn) => btn.addEventListener("click", () => showStep(Number(btn.dataset.step))));
    zonePrev.addEventListener("click", () => showStep(current - 1));
    zoneNext.addEventListener("click", () => showStep(current + 1));

    document.addEventListener("keydown", (e) => {
      if (e.key === "ArrowLeft") showStep(current - 1);
      if (e.key === "ArrowRight") showStep(current + 1);
    });

    let wheelBusy = false;
    let wheelReady = false;
    reader.addEventListener("wheel", (e) => {
      if (wheelBusy || Math.abs(e.deltaY) < 80) return;
      const el = steps[current].firstElementChild;
      const scrollable = el && el.scrollHeight > el.clientHeight;
      const atEdge = !scrollable || (
        (e.deltaY > 0 && el.scrollTop >= el.scrollHeight - el.clientHeight - 30) ||
        (e.deltaY < 0 && el.scrollTop <= 30)
      );
      if (!atEdge) { wheelReady = false; return; }
      if (wheelReady) {
        wheelReady = false;
        wheelBusy = true;
        setTimeout(() => { wheelBusy = false; }, 800);
        if (e.deltaY > 0) showStep(current + 1);
        else showStep(current - 1);
      } else {
        wheelReady = true;
      }
    });

    let overlayTimer: ReturnType<typeof setTimeout>;
    const step0Overlay = document.getElementById("step0-overlay")!;
    const animEndDelay = parseInt(step0Overlay.dataset.animEnd || "3200");

    function showStep0Overlay() {
      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;
      updateStep0Overlay(reader.dataset.language || "en");
      overlayTimer = setTimeout(() => {
        if (current !== 0) return;
        step0Overlay.classList.remove("opacity-0");
        stepContent.setAttribute("data-step0-animated", "");
        zonePrev.tabIndex = -1;
        zoneNext.tabIndex = -1;
      }, animEndDelay);
    }

    function hideStep0Overlay() {
      clearTimeout(overlayTimer);
      step0Overlay.remove();
      zonePrev.tabIndex = 0;
      zoneNext.tabIndex = 0;
    }

    const overlayClose = document.getElementById("overlayClose")!;
    step0Overlay.addEventListener("click", hideStep0Overlay);
    overlayClose.addEventListener("click", (e) => {
      e.stopPropagation();
      hideStep0Overlay();
    });

    if (current === 0) showStep0Overlay();
  </script>
</BaseLayout>